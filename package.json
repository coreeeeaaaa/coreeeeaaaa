{
  "name": "coreeeeaaaa",
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "publish": "npm publish --workspaces",
    "opa-check": "node scripts/opa-check.js",
    "serena:run": "uvx --from git+https://github.com/oraios/serena serena start-mcp-server --project . --port 3435",
